# =============================================================================
# Local Development Environment
# =============================================================================
# Copy this file to .env for local development: cp .env.example .env
# These values are for running `pnpm dev` locally (NOT for production)
#
# Production uses GitHub Secrets → docker-compose.override.yml (no .env file)
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="My Site"
NEXT_PUBLIC_SITE_DESCRIPTION="A personal website"

# -----------------------------------------------------------------------------
# Author Info (personalize your site - keep out of git)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AUTHOR_NAME="Your Name"
NEXT_PUBLIC_AUTHOR_EMAIL=you@example.com
NEXT_PUBLIC_AUTHOR_URL=https://example.com

# -----------------------------------------------------------------------------
# Social Links (leave empty if not used)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_GITHUB=
NEXT_PUBLIC_SOCIAL_LINKEDIN=
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_TIKTOK=
NEXT_PUBLIC_SOCIAL_YOUTUBE=
NEXT_PUBLIC_SOCIAL_DISCORD=

# -----------------------------------------------------------------------------
# Database (PostgreSQL) - Local instance
# -----------------------------------------------------------------------------
# Option 1: Connection URL (takes precedence if set)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mysite_dev

# Option 2: Individual settings (used if DATABASE_URL is not set)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mysite_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
# For local dev, any string works. Generate for production: openssl rand -base64 32
AUTH_SECRET=dev_secret_not_for_production
AUTH_URL=http://localhost:3000

# Session duration in seconds (default: 86400 = 24 hours)
# AUTH_SESSION_DURATION=86400

# CSRF Secret (used for form protection)
# CSRF_SECRET=csrf-dev-secret

# -----------------------------------------------------------------------------
# Admin Credentials (for database seeding only)
# -----------------------------------------------------------------------------
# Used when running: pnpm seed:admin
ADMIN_EMAIL=admin@localhost.com
ADMIN_PASSWORD=devpassword123
ADMIN_NAME=Admin

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# Max file size in MB (default: 50)
# UPLOAD_MAX_SIZE_MB=50

# Allowed MIME types (comma-separated)
# UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml,application/pdf,text/plain,text/markdown

# Upload path (default: /uploads)
# UPLOAD_PATH=/uploads

# Generate image variants/thumbnails (default: true)
# UPLOAD_GENERATE_VARIANTS=true

# Maximum dimension for images (default: 4096)
# UPLOAD_MAX_DIMENSION=4096

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Window duration in milliseconds (default: 900000 = 15 minutes)
# RATE_LIMIT_WINDOW_MS=900000

# Max requests per window (default: 100)
# RATE_LIMIT_MAX_REQUESTS=100

# Max login attempts per window (default: 5)
# RATE_LIMIT_LOGIN_MAX=5
